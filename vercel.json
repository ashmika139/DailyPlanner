{
    "version": 2,
    "rewrites": [
        {
            "source": "/",
            "destination": "/public/index.html"
        },
        {
            "source": "/([^/\\.]+)\\.html",
            "destination": "/public/$1.html"
        },
        {
            "source": "/style\\.css",
            "destination": "/public/style.css"
        },
        {
            "source": "/script\\.js",
            "destination": "/public/script.js"
        },
        {
            "source": "/(?!api/)(.*)",
            "destination": "/public/$1"
        }
    ]
}