{
    "version": 2,
    "builds": [
        {
            "src": "api/**/*.js",
            "use": "@vercel/node"
        },
        {
            "src": "public/**/*",
            "use": "@vercel/static"
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/",
            "destination": "/public/index.html"
        },
        {
            "source": "/([^/\\.]+)\\.html",
            "destination": "/public/$1.html"
        },
        {
            "source": "/style\\.css",
            "destination": "/public/style.css"
        },
        {
            "source": "/script\\.js",
            "destination": "/public/script.js"
        },
        {
            "source": "/(.*)",
            "destination": "/public/$1"
        }
    ]
}